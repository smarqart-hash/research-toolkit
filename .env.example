# Semantic Scholar API Key (optional, recommended for higher rate limits)
# Get yours at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# Exa API Key (optional, extends search coverage)
# Get yours at: https://exa.ai — 1000 free requests/month
EXA_API_KEY=

# Default venue profile (working_paper, conference_paper, literature_review,
# policy_brief, research_report, position_paper, arxiv_cs_ai, nature_communications)
DEFAULT_VENUE=working_paper

# Default voice profile (academic_en, academic_de)
DEFAULT_VOICE=academic_en

# Output directory for generated files
OUTPUT_DIR=./output