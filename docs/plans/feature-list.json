        "load_venue_profile() laedt sie korrekt",
        "Tests fuer Schema-Validierung"
      ],
      "status": "done"
    },
    {
      "id": "F-004",
      "name": "Code Review Batch 1",
      "batch": 1,
      "agent": "code-reviewer",
      "repo": "research-toolkit",
      "depends_on": ["F-001", "F-002", "F-003"],
