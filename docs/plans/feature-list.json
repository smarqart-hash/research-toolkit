      "id": "F-001",
      "name": "decompose_topic() — LLM-basierte Subject Decomposition",
      "batch": 1,
      "agent": "builder",
      "repo": "research-toolkit",
      "depends_on": [],
      "acceptance_criteria": [
        "Funktion in src/agents/topic_decomposer.py",
        "Nutzt llm_complete() via OpenRouter (Haiku)",
        "Output: JSON mit topic, research_question, scope, core_terms, exclusions, facets[]",
        "Jede Facette hat name, description, search_query",
        "JSON-Schema-Validation auf Output",
        "Fallback bei Garbage: min 2, max 8 Facetten",
        "Tests in tests/test_topic_decomposer.py"
      ],
      "status": "done"
    },
    {
      "id": "F-002",
      "name": "4 neue Voice-Profile (konservativ, progressiv, B1, executive)",
      "batch": 1,
      "agent": "builder",
      "repo": "research-toolkit",
      "depends_on": [],
      "acceptance_criteria": [
        "config/voice_profiles/konservativ_de_voice.json",
        "config/voice_profiles/progressiv_de_voice.json",
        "config/voice_profiles/b1_de_voice.json",
        "config/voice_profiles/executive_en_voice.json",
        "Alle folgen bestehendem VoiceProfile Schema (Pydantic)",
        "load_voice_profile() laedt sie korrekt",
        "Tests fuer Schema-Validierung"
      ],
      "status": "done"
    },
    {
      "id": "F-003",
      "name": "2 neue Venue-Profile (quick_impuls, executive_brief)",
